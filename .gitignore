# Secrets — never committed
.env

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Backups (large binary archives)
backup/
addons backup/

# Old working copy
ha-tools-hub(Pre Upgrade Working)/

# Virtual environments
.venv/
venv/
env/

# Archives
*.zip
*.gz

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Node (if ever needed)
node_modules/

# GUI runtime state
gui/server_config.json

# Companion addon configs — kept local only so HA supervisor does not
# surface companions in the Add-on Store before the main addon installs them.
# The config.yaml files exist in the working tree for local development/build
# but must not be pushed to GitHub.
ha-tools-hub/companions/*/config.yaml
